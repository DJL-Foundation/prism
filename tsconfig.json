{
  "compilerOptions": {
    /* Base Options: */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "es2022",
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,

    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "checkJs": true,

    /* Bundled projects */
    "lib": ["dom", "dom.iterable", "ES2022"],
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "incremental": true,

    /* Path Aliases */
    "baseUrl": ".",
    "paths": {
      "#env": ["./src/env.js"],
      "#flags": ["./src/server/flags.ts"],
      "#utility": ["./src/server/utility.ts"],
      "#db": ["./src/server/db.ts"],
      "#auth": ["./src/server/auth.ts"],
      "#auth/client": ["./src/server/auth-client.ts"],
      "#auth/client.mock": ["./src/server/auth-client.mock.ts"],
      "#storybook/*": ["./.storybook/*"],
      "#logger": ["./src/lib/logging.ts"],
      "~/*": ["./src/*"],
      "@/*": ["./*"],
    }
  },
  "include": [
    ".eslintrc.cjs",
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.cjs",
    "**/*.js",
    ".next/types/**/*.ts",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
  ],
  "exclude": ["node_modules"]
}
