    "react-resizable-panels": "^4.1.0",
    "recharts": "3.6.0",
    "require-in-the-middle": "^8.0.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.6",
    "superjson": "^2.2.2",
    "tailwind-merge": "^3.3.1",
