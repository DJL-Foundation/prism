  "repository": {
    "type": "git",
    "url": "https://github.com/JackatDJL/presentation-foundation.git"
  },
  "type": "module",
  "scripts": {
    "build": "next build --turbo",
    "check": "biome check . && tsc --noEmit",
    "dev": "next dev --turbo",
    "format:check": "biome check .",
    "format:write": "biome format . --write",
    "postinstall": "npm-run-all -p postinstall:*",
    "postinstall:scripts": "bun /scripts/postinstall.ts",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "mcp": "mcp-inspector",
    "auth:generate": "cli generate"
  },
  "imports": {
    "#env": {
      "default": "./src/env.js"
    },
    "#flags": {
      "default": "./src/server/flags.ts"
    },
    "#utility": {
      "default": "./src/server/utility.ts"
    },
    "#db": {
      "default": "./src/server/db.ts"
    },
    "#auth": {
      "default": "./src/server/auth.ts"
    },
    "#auth/client": {
      "test": "./src/server/auth-client.mock.ts",
      "default": "./src/server/auth-client.ts"
    },
    "#auth/client.mock": {
      "default": "./src/server/auth-client.mock.ts"
    },
    "#logger": {
      "default": "./src/lib/logging.ts"
    }
  },
