{
  "name": "@djl-foundation/presentation-foundation",
  "version": "0.1.0",
  "private": true,
  "author": {
    "name": "JackatDJL",
    "email": "jack@djl.foundation",
    "url": "https://jack.djl.foundation"
  },
  "homepage": "https://pr.djl.foundation",
  "icon": "https://djl.foundation/favicon.ico",
  "license": "Apache-2.0",
  "l10n": "en",
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "publisher": "DJL Foundation",
  "description": "A OSS SaaS for Document and Keynote distribution via a Multi-Tenant Web Application",
  "keywords": [
    "SaaS",
    "Document Distribution",
    "Keynote Distribution",
    "Multi-Tenant",
    "DJL Foundation",
    "Open Source",
    "Next.js",
    "TypeScript",
    "Prisma",
    "PostgreSQL",
    "Tailwind CSS",
    "Radix UI",
    "React",
    "Serverless",
    "Vercel",
    "MCP",
    "Model Context Protocol",
    "Flags SDK",
    "PostHog",
    "Auth",
    "Better Auth",
    "JackatDJL"
  ],
  "bugs": {
    "url": "https://github.com/JackatDJL/presentation-foundation/issues",
    "email": "issues@djl.foundation"
  },
  "displayName": "The Presentation Foundation",
  "repository": {
    "type": "git",
    "url": "https://github.com/JackatDJL/presentation-foundation.git"
  },
  "type": "module",
  "scripts": {
    "build": "next build --turbo",
    "check": "next lint && tsc --noEmit",
    "dev": "next dev --turbo",
    "convex:dev": "bunx convex dev",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "postinstall": "npm-run-all -p postinstall:*",
    "postinstall:prisma": "prisma generate",
    "postinstall:scripts": "bun /scripts/postinstall.ts",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "preview": "next build && next start",
    "start": "next start",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "SKIP_ENV_VALIDATION=1 storybook build",
    "mcp": "mcp-inspector",
    "auth:generate": "cli generate",
    "chromatic": "chroma --exit-zero-on-changes"
  },
  "imports": {
    "#env": {
      "default": "./src/env.js"
    },
    "#flags": {
      "default": "./src/server/flags.ts"
    },
    "#utility": {
      "default": "./src/server/utility.ts"
    },
    "#db": {
      "default": "./src/server/db.ts"
    },
    "#auth": {
      "default": "./src/server/auth.ts"
    },
    "#auth/client": {
      "test": "./src/server/auth-client.mock.ts",
      "default": "./src/server/auth-client.ts"
    },
    "#auth/client.mock": {
      "default": "./src/server/auth-client.mock.ts"
    },
    "#logger": {
      "default": "./src/lib/logging.ts"
    }
  },
  "dependencies": {
    "@emotion/styled": "^11.14.1",
